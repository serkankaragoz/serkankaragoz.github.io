---
import { site } from '@config/site';

const g = site.giscus;
if (!g.enabled) return;

const attrs = {
  'data-repo': g.repo,
  'data-repo-id': g.repoId,
  'data-category': g.category,
  'data-category-id': g.categoryId,
  'data-mapping': g.mapping,
  'data-strict': g.strict ? '1' : '0',
  'data-reactions-enabled': g.reactionsEnabled ? '1' : '0',
  'data-emit-metadata': '0',
  'data-input-position': g.inputPosition,
  'data-theme': g.lightTheme,
  'data-lang': g.lang,
  crossorigin: 'anonymous',
  async: true,
};
---

<section
  class="giscus-comments mt-12 pt-8"
  style="border-top: 1px solid var(--global-divider-color);"
>
  {g.lazyLoad ? (
    /* Consent opt-in: giscus.app is not loaded until the user clicks */
    <div id="giscus-consent">
      <p class="giscus-notice">
        Comments are powered by <a href="https://giscus.app" target="_blank" rel="noopener noreferrer">Giscus</a>
        (GitHub Discussions). Loading them fetches resources from GitHub.
      </p>
      <button id="giscus-load-btn" class="giscus-btn">Load comments</button>
    </div>
    <div class="giscus" id="giscus-container" hidden></div>
  ) : (
    <div class="giscus"></div>
  )}
</section>

{g.lazyLoad ? (
  <script is:inline define:vars={{
    giscusAttrs: attrs,
    darkTheme: g.darkTheme,
    lightTheme: g.lightTheme,
  }}>
    function loadGiscus() {
      var consent = document.getElementById('giscus-consent');
      var container = document.getElementById('giscus-container');
      if (!consent || !container) return;
      consent.hidden = true;
      container.hidden = false;

      var s = document.createElement('script');
      s.src = 'https://giscus.app/client.js';
      Object.entries(giscusAttrs).forEach(function([k, v]) {
        if (k === 'async') { s.async = true; return; }
        s.setAttribute(k, String(v));
      });
      // Set correct initial theme
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      s.setAttribute('data-theme', isDark ? darkTheme : lightTheme);
      container.appendChild(s);
    }

    var btn = document.getElementById('giscus-load-btn');
    if (btn) btn.addEventListener('click', loadGiscus);

    // Theme sync — only active after giscus has loaded
    function sendGiscusTheme(theme) {
      var iframe = document.querySelector('iframe.giscus-frame');
      if (!iframe) return;
      iframe.contentWindow.postMessage({ giscus: { setConfig: { theme: theme } } }, 'https://giscus.app');
    }
    new MutationObserver(function() {
      var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      sendGiscusTheme(isDark ? darkTheme : lightTheme);
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  </script>
) : (
  <>
    <script
      src="https://giscus.app/client.js"
      data-repo={g.repo}
      data-repo-id={g.repoId}
      data-category={g.category}
      data-category-id={g.categoryId}
      data-mapping={g.mapping}
      data-strict={g.strict ? '1' : '0'}
      data-reactions-enabled={g.reactionsEnabled ? '1' : '0'}
      data-emit-metadata="0"
      data-input-position={g.inputPosition}
      data-theme={g.lightTheme}
      data-lang={g.lang}
      crossorigin="anonymous"
      async></script>
    <script is:inline define:vars={{ darkTheme: g.darkTheme, lightTheme: g.lightTheme }}>
      function sendGiscusTheme(theme) {
        var iframe = document.querySelector('iframe.giscus-frame');
        if (!iframe) return;
        iframe.contentWindow.postMessage({ giscus: { setConfig: { theme: theme } } }, 'https://giscus.app');
      }
      new MutationObserver(function() {
        var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        sendGiscusTheme(isDark ? darkTheme : lightTheme);
      }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    </script>
  </>
)}

<style>
  .giscus-notice {
    font-size: 0.85rem;
    color: var(--global-text-color-light);
    margin-bottom: 0.75rem;
  }

  .giscus-notice a {
    color: var(--global-theme-color);
    text-decoration: none;
  }

  .giscus-notice a:hover {
    text-decoration: underline;
  }

  .giscus-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1.1rem;
    border-radius: 4px;
    border: 1px solid var(--global-divider-color);
    background: transparent;
    color: var(--global-text-color);
    font-size: 0.875rem;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .giscus-btn:hover {
    border-color: var(--global-theme-color);
    color: var(--global-theme-color);
  }
</style>
