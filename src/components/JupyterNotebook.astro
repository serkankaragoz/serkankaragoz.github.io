---
// src/components/JupyterNotebook.astro
// Renders Jupyter notebook cells in a style similar to the Jupyter web UI.

interface Output {
  output_type: string;
  text?: string[];
  data?: {
    'text/plain'?: string[];
    'text/html'?: string[];
  };
  execution_count?: number | null;
}

interface Cell {
  cell_type: 'code' | 'markdown' | 'raw';
  source: string[];
  outputs?: Output[];
  execution_count?: number | null;
}

interface Props {
  cells: Cell[];
  language?: string;
}

const { cells, language = 'python' } = Astro.props;

function joinSource(source: string[]): string {
  return source.join('');
}

function getOutputText(output: Output): string {
  if (output.text) return output.text.join('');
  if (output.data) {
    if (output.data['text/plain']) return output.data['text/plain'].join('');
  }
  return '';
}

function getOutputHtml(output: Output): string | null {
  if (output.data?.['text/html']) return output.data['text/html'].join('');
  return null;
}

// Count only code cells for numbering
let codeCount = 0;
const numberedCells = cells.map((cell) => {
  if (cell.cell_type === 'code') {
    codeCount++;
    return { ...cell, cellNumber: codeCount };
  }
  return { ...cell, cellNumber: null };
});
---

<div class="jupyter-notebook not-prose my-8 font-mono text-sm">
  {
    numberedCells.map((cell) => {
      if (cell.cell_type === 'markdown') {
        return (
          <div class="jupyter-cell jupyter-markdown-cell mb-4 px-2 py-3">
            <div
              class="prose prose-sm dark:prose-invert max-w-none font-sans"
              set:html={joinSource(cell.source)}
            />
          </div>
        );
      }

      if (cell.cell_type === 'raw') {
        return (
          <div class="jupyter-cell jupyter-raw-cell mb-4 rounded border border-gray-200 px-3 py-2 dark:border-gray-700">
            <pre class="text-xs whitespace-pre-wrap text-gray-600 dark:text-gray-400">
              {joinSource(cell.source)}
            </pre>
          </div>
        );
      }

      // code cell
      const src = joinSource(cell.source);
      const num = cell.cellNumber;
      const outputs = cell.outputs ?? [];

      return (
        <div class="jupyter-cell jupyter-code-cell mb-4">
          {/* Input area */}
          <div class="flex gap-2">
            <div class="jupyter-prompt jupyter-in-prompt w-16 shrink-0 pt-3 text-right text-xs text-blue-600 dark:text-blue-400">
              In [{num ?? ' '}]:
            </div>
            <div class="min-w-0 flex-1 overflow-x-auto rounded border-l-4 border-blue-400 bg-gray-100 dark:border-blue-600 dark:bg-gray-800">
              <pre class={`language-${language} m-0 p-3 text-xs leading-relaxed`}>
                <code class={`language-${language}`}>{src}</code>
              </pre>
            </div>
          </div>

          {/* Output area */}
          {outputs.length > 0 && (
            <div class="mt-1 flex gap-2">
              <div class="jupyter-prompt jupyter-out-prompt w-16 shrink-0 pt-2 text-right text-xs text-red-600 dark:text-red-400">
                {outputs.some(
                  (o) => o.output_type === 'execute_result' || o.output_type === 'display_data',
                )
                  ? `Out [${num ?? ' '}]:`
                  : ''}
              </div>
              <div class="min-w-0 flex-1 overflow-x-auto rounded border-l-4 border-red-300 bg-white py-2 dark:border-red-700 dark:bg-gray-900">
                {outputs.map((output) => {
                  const html = getOutputHtml(output);
                  const text = getOutputText(output);

                  if (html) {
                    return <div class="px-3 text-xs" set:html={html} />;
                  }

                  if (text) {
                    return (
                      <pre class="m-0 px-3 text-xs leading-relaxed whitespace-pre-wrap text-gray-800 dark:text-gray-200">
                        {text}
                      </pre>
                    );
                  }

                  return null;
                })}
              </div>
            </div>
          )}
        </div>
      );
    })
  }
</div>

<style>
  .jupyter-notebook {
    border: 1px solid #e5e7eb;
    border-radius: 0.5rem;
    padding: 1rem;
    background-color: #ffffff;
  }

  :global(html[data-theme='dark']) .jupyter-notebook {
    border-color: #374151;
    background-color: #111827;
  }

  .jupyter-code-cell pre {
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', 'Monaco', monospace;
  }
</style>
