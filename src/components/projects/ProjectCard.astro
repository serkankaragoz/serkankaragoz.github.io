---
import { site } from '@config/site';
import { withBase } from '@utils/base';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const href = project.data.redirect ?? project.data.url ?? `${site.base}/projects/${project.id}/`;
const isExternal = !!project.data.redirect;
---

<div class="col">
  <div
    class="card hoverable h-100"
    data-href={href}
    data-external={isExternal ? 'true' : undefined}
  >
    {
      project.data.img && (
        <img
          src={withBase(project.data.img)}
          alt={project.data.img_alt ?? project.data.title}
          loading="lazy"
          width="400"
          height="200"
          class="card-img-top"
        />
      )
    }
    <div class="card-body">
      <h2 class="card-title">
        <a
          href={href}
          target={isExternal ? '_blank' : undefined}
          rel={isExternal ? 'noopener noreferrer' : undefined}
          class="card-title-link"
        >
          {project.data.title}
        </a>
      </h2>
      {project.data.description && <p class="card-text">{project.data.description}</p>}
      {
        project.data.github && (
          <div class="row-icons">
            <div class="github-icon">
              <div class="icon" title="Code Repository" data-tooltip="Code Repository">
                <a
                  href={`https://github.com/${project.data.github}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${project.data.title} on GitHub`}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 16 16"
                    fill="currentColor"
                    class="gh-icon"
                    aria-hidden="true"
                  >
                    <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                  </svg>
                </a>
              </div>
              {project.data.github_stars && (
                <span class="stars" title="GitHub Stars" data-tooltip="GitHub Stars">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 16 16"
                    fill="currentColor"
                    width="12"
                    height="12"
                    aria-hidden="true"
                  >
                    <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z" />
                  </svg>
                  <span data-github-stars={project.data.github_stars} />
                </span>
              )}
            </div>
          </div>
        )
      }
    </div>
  </div>
</div>

<style>
  .col {
    padding: 0 0.5rem;
    margin-bottom: 1rem;
    flex: 0 0 100%;
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .col {
      flex: 0 0 50%;
      max-width: 50%;
    }
  }

  @media (min-width: 992px) {
    .col {
      flex: 0 0 33.333%;
      max-width: 33.333%;
    }
  }

  .card {
    border: 1px solid var(--global-divider-color);
    border-radius: 4px;
    background-color: var(--global-card-bg-color);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .h-100 {
    height: 100%;
  }

  .hoverable {
    transition: box-shadow 0.25s ease;
  }

  .hoverable:hover {
    box-shadow:
      0 5px 11px 0 rgba(0, 0, 0, 0.18),
      0 4px 15px 0 rgba(0, 0, 0, 0.15);
  }

  .card-img-top {
    width: 100%;
    height: 200px;
    display: block;
    object-fit: cover;
  }

  .card-body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
  }

  .card-title-link {
    color: var(--global-text-color);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .card:hover .card-title-link {
    color: var(--global-theme-color);
  }

  .card-text {
    color: var(--global-text-color-light);
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .row-icons {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .github-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .github-icon .icon a {
    color: var(--global-text-color);
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
  }

  .github-icon .icon a:hover {
    color: var(--global-theme-color);
  }

  .gh-icon {
    width: 1.1rem;
    height: 1.1rem;
  }

  .stars {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
    font-size: 0.8rem;
    color: var(--global-text-color-light);
  }
</style>
