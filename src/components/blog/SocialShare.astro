---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  url: string;
  description?: string;
}

const { title, url, description = '' } = Astro.props;

const enc = {
  url: encodeURIComponent(url),
  title: encodeURIComponent(title),
  description: encodeURIComponent(description),
};

const shareLinks = [
  {
    name: 'X (Twitter)',
    href: `https://twitter.com/intent/tweet?text=${enc.title}&url=${enc.url}`,
    icon: 'fa-brands:twitter',
  },
  {
    name: 'LinkedIn',
    href: `https://www.linkedin.com/shareArticle?mini=true&url=${enc.url}&title=${enc.title}`,
    icon: 'fa-brands:linkedin',
  },
  {
    name: 'Facebook',
    href: `https://www.facebook.com/sharer/sharer.php?u=${enc.url}`,
    icon: 'fa-brands:facebook',
  },
  {
    name: 'Email',
    href: `mailto:?subject=${enc.title}&body=${enc.description}%0A%0A${enc.url}`,
    icon: 'fa-solid:envelope',
  },
];
---

<div class="social-share">
  <p class="share-label">Share</p>
  <div class="share-icons">
    {
      shareLinks.map(({ name, href, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Share on ${name}`}
          title={`Share on ${name}`}
          class="share-link"
        >
          <Icon name={icon} aria-hidden="true" />
        </a>
      ))
    }
    <button
      id="native-share-btn"
      aria-label="Share via device"
      title="Share via device"
      class="share-link share-native"
      hidden
    >
      <Icon name="fa-solid:share-alt" aria-hidden="true" />
    </button>
  </div>
</div>

<script define:vars={{ shareTitle: title, shareUrl: url, shareText: description }}>
  const btn = document.getElementById('native-share-btn');
  if (navigator.share && btn) {
    btn.hidden = false;
    btn.addEventListener('click', () => {
      navigator.share({ title: shareTitle, url: shareUrl, text: shareText }).catch(() => {});
    });
  }
</script>

<style>
  .social-share {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--global-divider-color);
  }

  .share-label {
    font-size: 0.875rem;
    color: var(--global-text-color-light);
    margin-bottom: 0.5rem;
  }

  .share-icons {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .share-link {
    color: var(--global-text-color-light);
    font-size: 1.1rem;
    line-height: 1;
    text-decoration: none;
    transition: color 0.15s ease;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .share-link:hover {
    color: var(--global-theme-color);
  }
</style>
