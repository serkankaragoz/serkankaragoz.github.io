---
import type { MarkdownHeading } from 'astro';

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;

// Only render h2 and h3
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
if (tocHeadings.length === 0) return;
---

<nav
  aria-label="Table of contents"
  class="toc sticky top-20"
  style="font-size: 0.8rem; max-height: calc(100vh - 6rem); overflow-y: auto;"
>
  <p
    class="mb-2 font-semibold tracking-wide uppercase"
    style="font-size: 0.7rem; color: var(--global-text-color-light);"
  >
    Table of Contents
  </p>
  <ul class="space-y-1" style="list-style: none; padding: 0; margin: 0;">
    {
      tocHeadings.map((h) => (
        <li style={h.depth === 3 ? 'padding-left: 0.75rem;' : ''}>
          <a
            href={`#${h.slug}`}
            class="toc-link block py-0.5 transition-colors"
            style="color: var(--global-text-color-light); text-decoration: none; line-height: 1.4;"
          >
            {h.text}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  // Highlight the active heading as user scrolls
  const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
  const headingIds = Array.from(links).map((l) => l.getAttribute('href')?.slice(1) ?? '');

  function setActive(id: string) {
    links.forEach((l) => {
      const isActive = l.getAttribute('href') === `#${id}`;
      l.style.color = isActive ? 'var(--global-theme-color)' : 'var(--global-text-color-light)';
      l.style.fontWeight = isActive ? '600' : '400';
    });
  }

  const navbarHeight =
    parseInt(getComputedStyle(document.documentElement).getPropertyValue('--navbar-height')) || 57;

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          setActive(entry.target.id);
          break;
        }
      }
    },
    { rootMargin: `-${navbarHeight}px 0px -80% 0px`, threshold: 0 },
  );

  headingIds.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>

<style>
  .toc-link:hover {
    color: var(--global-theme-color) !important;
  }
</style>
