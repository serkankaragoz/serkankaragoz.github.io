---
import { site } from '@config/site';

if (!site.features.newsletter || !site.newsletter.endpoint) return;
---

<section class="newsletter-section">
  <div class="page-container">
    <form action={site.newsletter.endpoint} method="POST" class="newsletter-form">
      <h3 class="newsletter-title">Subscribe to updates</h3>
      <p class="newsletter-desc">Get notified about new posts and announcements.</p>
      <div class="newsletter-fields">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="newsletter-input"
          aria-label="Email address"
        />
        <button type="submit" class="newsletter-btn">Subscribe</button>
      </div>
    </form>
  </div>
</section>

<style>
  .newsletter-section {
    background-color: var(--global-card-bg-color);
    border-top: 1px solid var(--global-divider-color);
    padding: 2rem 0;
    margin-top: 2rem;
  }

  .newsletter-form {
    text-align: center;
    max-width: 480px;
    margin: 0 auto;
  }

  .newsletter-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--global-text-color);
    font-family: var(--font-sans);
    margin-bottom: 0.25rem;
  }

  .newsletter-desc {
    font-size: 0.875rem;
    color: var(--global-text-color-light);
    margin-bottom: 1rem;
  }

  .newsletter-fields {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .newsletter-input {
    flex: 1;
    min-width: 0;
    max-width: 280px;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--global-divider-color);
    border-radius: 4px;
    background-color: var(--global-bg-color);
    color: var(--global-text-color);
    font-size: 0.875rem;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.15s ease;
  }

  .newsletter-input:focus {
    border-color: var(--global-theme-color);
  }

  .newsletter-btn {
    padding: 0.5rem 1.25rem;
    background-color: var(--global-theme-color);
    color: var(--global-hover-text-color);
    border: none;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: var(--font-sans);
    cursor: pointer;
    transition: opacity 0.15s ease;
    white-space: nowrap;
  }

  .newsletter-btn:hover {
    opacity: 0.85;
  }
</style>
