---
/**
 * AudioPlayer component — accessible HTML5 audio player.
 *
 * Usage in MDX:
 *   import AudioPlayer from '@components/AudioPlayer.astro';
 *   <AudioPlayer src="/assets/audio/clip.mp3" title="My Recording" />
 */

interface Props {
  /** Path or URL to the audio file */
  src: string;
  /** Display title for the audio */
  title?: string;
  /** Optional caption shown below the player */
  caption?: string;
  /** MIME type (auto-detected from extension if omitted) */
  type?: string;
}

import { withBase } from '@utils/base';

const { src: srcProp, title, caption, type } = Astro.props;
const src = withBase(srcProp);

// Auto-detect MIME type from extension
function getMimeType(url: string, explicit?: string): string {
  if (explicit) return explicit;
  const ext = url.split('.').pop()?.toLowerCase();
  const map: Record<string, string> = {
    mp3: 'audio/mpeg',
    ogg: 'audio/ogg',
    wav: 'audio/wav',
    flac: 'audio/flac',
    aac: 'audio/aac',
    m4a: 'audio/mp4',
    opus: 'audio/opus',
    webm: 'audio/webm',
  };
  return map[ext ?? ''] ?? 'audio/mpeg';
}

const mimeType = getMimeType(src, type);
---

<figure class="audio-figure">
  {title && <figcaption class="audio-title">{title}</figcaption>}
  <audio controls class="audio-player">
    <source src={src} type={mimeType} />
    Your browser does not support the audio element.
    <a href={src} download>Download audio</a>
  </audio>
  {caption && <p class="audio-caption">{caption}</p>}
</figure>

<style>
  .audio-figure {
    margin: 1.5rem 0;
  }

  .audio-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--global-text-color-light);
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
  }

  .audio-player {
    width: 100%;
    border-radius: 4px;
  }

  .audio-caption {
    font-size: 0.8rem;
    color: var(--global-text-color-light);
    margin-top: 0.5rem;
    text-align: center;
    font-style: italic;
  }
</style>
