---
interface Props {
  /** URL of the previous page (undefined if on first page). */
  prevUrl?: string;
  /** URL of the next page (undefined if on last page). */
  nextUrl?: string;
  /** Current page number (1-based). */
  currentPage: number;
  /** Total number of pages. */
  totalPages: number;
  /** Base path for page links, e.g. '/blog/'. Page N links to base + N. */
  basePath: string;
}

const { prevUrl, nextUrl, currentPage, totalPages, basePath } = Astro.props;
if (totalPages <= 1) return;

// Build page number list with ellipsis
function buildPageList(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | '...')[] = [1];
  if (current > 3) pages.push('...');
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push('...');
  pages.push(total);
  return pages;
}

const pageList = buildPageList(currentPage, totalPages);

function pageUrl(n: number): string {
  return n === 1 ? basePath : `${basePath}page/${n}/`;
}
---

<nav aria-label="Pagination" class="mt-8 flex flex-wrap items-center justify-center gap-1">
  <!-- Previous -->
  {
    prevUrl ? (
      <a
        href={prevUrl}
        aria-label="Previous page"
        class="pagination-btn"
        style="padding: 0.35rem 0.65rem; border-radius: 4px; text-decoration: none; color: var(--global-text-color); border: 1px solid var(--global-divider-color);"
      >
        &laquo;
      </a>
    ) : (
      <span
        aria-disabled="true"
        style="padding: 0.35rem 0.65rem; border-radius: 4px; color: var(--global-text-color-light); border: 1px solid var(--global-divider-color); opacity: 0.5;"
      >
        &laquo;
      </span>
    )
  }

  <!-- Page numbers -->
  {
    pageList.map((p) =>
      p === '...' ? (
        <span style="padding: 0.35rem 0.25rem; color: var(--global-text-color-light);">…</span>
      ) : (
        <a
          href={pageUrl(p as number)}
          aria-label={`Page ${p}`}
          aria-current={p === currentPage ? 'page' : undefined}
          class="pagination-btn"
          style={`padding: 0.35rem 0.65rem; border-radius: 4px; text-decoration: none; border: 1px solid ${p === currentPage ? 'var(--global-theme-color)' : 'var(--global-divider-color)'}; color: ${p === currentPage ? 'var(--global-hover-text-color)' : 'var(--global-text-color)'}; background-color: ${p === currentPage ? 'var(--global-theme-color)' : 'transparent'};`}
        >
          {p}
        </a>
      ),
    )
  }

  <!-- Next -->
  {
    nextUrl ? (
      <a
        href={nextUrl}
        aria-label="Next page"
        class="pagination-btn"
        style="padding: 0.35rem 0.65rem; border-radius: 4px; text-decoration: none; color: var(--global-text-color); border: 1px solid var(--global-divider-color);"
      >
        &raquo;
      </a>
    ) : (
      <span
        aria-disabled="true"
        style="padding: 0.35rem 0.65rem; border-radius: 4px; color: var(--global-text-color-light); border: 1px solid var(--global-divider-color); opacity: 0.5;"
      >
        &raquo;
      </span>
    )
  }
</nav>

<style>
  .pagination-btn:hover {
    background-color: var(--global-hover-color) !important;
  }
</style>
