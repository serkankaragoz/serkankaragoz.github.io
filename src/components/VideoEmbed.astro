---
/**
 * VideoEmbed component — responsive video embed for YouTube, Vimeo, or direct MP4.
 *
 * Usage in MDX:
 *   import VideoEmbed from '@components/VideoEmbed.astro';
 *   <VideoEmbed src="https://www.youtube.com/watch?v=dQw4w9WgXcQ" />
 *   <VideoEmbed src="https://vimeo.com/123456789" title="My Video" />
 *   <VideoEmbed src="/assets/video/demo.mp4" />
 */

interface Props {
  /** YouTube URL, Vimeo URL, or direct video file path */
  src: string;
  /** Accessible title for iframe / video element */
  title?: string;
  /** Optional caption shown below the embed */
  caption?: string;
  /** Aspect ratio (default: '16/9') */
  aspect?: '16/9' | '4/3' | '1/1' | '9/16';
}

const { src, title = 'Video', caption, aspect = '16/9' } = Astro.props;

function getEmbedUrl(rawSrc: string): { type: 'youtube' | 'vimeo' | 'direct'; url: string } {
  // YouTube
  const ytMatch = rawSrc.match(
    /(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/,
  );
  if (ytMatch) {
    return { type: 'youtube', url: `https://www.youtube.com/embed/${ytMatch[1]}?rel=0` };
  }
  // Vimeo
  const vimeoMatch = rawSrc.match(/vimeo\.com\/(\d+)/);
  if (vimeoMatch) {
    return { type: 'vimeo', url: `https://player.vimeo.com/video/${vimeoMatch[1]}` };
  }
  // Direct file
  return { type: 'direct', url: rawSrc };
}

const embed = getEmbedUrl(src);

// Padding-bottom for aspect ratios
const aspectPad: Record<string, string> = {
  '16/9': '56.25%',
  '4/3': '75%',
  '1/1': '100%',
  '9/16': '177.78%',
};
const pad = aspectPad[aspect] ?? '56.25%';
---

<figure class="video-figure">
  <div class="video-wrapper" style={`padding-bottom: ${pad};`}>
    {
      embed.type === 'direct' ? (
        <video controls title={title} class="video-el">
          <source src={embed.url} />
          Your browser does not support video playback.
          <a href={embed.url} download>
            Download video
          </a>
        </video>
      ) : (
        <iframe
          src={embed.url}
          title={title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        />
      )
    }
  </div>
  {caption && <figcaption class="video-caption">{caption}</figcaption>}
</figure>

<style>
  .video-figure {
    margin: 1.5rem 0;
  }

  .video-wrapper {
    position: relative;
    width: 100%;
    height: 0;
    overflow: hidden;
    border-radius: 4px;
    background: #000;
  }

  .video-wrapper iframe,
  .video-wrapper .video-el {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-caption {
    font-size: 0.8rem;
    color: var(--global-text-color-light);
    margin-top: 0.5rem;
    text-align: center;
    font-style: italic;
  }
</style>
