---
/**
 * Figure — equivalent to al-folio's figure.liquid include.
 *
 * Usage in MDX (al-folio compatible):
 *   import Figure from '@components/Figure.astro';
 *
 *   <Figure path="/assets/img/1.jpg" class="img-fluid rounded z-depth-1" />
 *   <Figure path="/assets/img/2.jpg" class="img-fluid rounded z-depth-1" caption="My caption" />
 *   <Figure path="/assets/img/icon.png" class="img-fluid" zoomable={false} />
 *   <Figure path="/assets/img/3.jpg" class="img-fluid rounded z-depth-1" slot="first" />
 *
 * Legacy API (as-folio v1):
 *   <Figure src="/assets/img/1.jpg" alt="desc" caption="text" align="center" />
 */

interface Props {
  /** Image path — primary prop (matches al-folio figure.liquid) */
  path?: string;
  /** Legacy: same as path */
  src?: string;
  /** CSS classes on the img element (e.g., "img-fluid rounded z-depth-1") */
  class?: string;
  /** Alt text */
  alt?: string;
  /** Title attribute */
  title?: string;
  /** Caption shown below the image */
  caption?: string;
  /** Disable medium-zoom click-to-zoom (adds class no-zoom). Default: true (all figures are zoomable). */
  zoomable?: boolean;
  /** Loading strategy */
  loading?: 'lazy' | 'eager';
  /** Width attribute */
  width?: string | number;
  /** Height attribute */
  height?: string | number;
  /** For image comparison slider (slot="first" or slot="second") */
  slot?: string;
}

const {
  path,
  src,
  class: className = 'img-fluid rounded z-depth-1',
  alt = '',
  title,
  caption,
  zoomable = true,
  loading = 'lazy',
  width = '100%',
  height = 'auto',
  slot: slotName,
} = Astro.props;

import { withBase } from '@utils/base';

const imgSrc = withBase(path ?? src ?? '');
const imgClass = zoomable ? className : `${className} no-zoom`.trim();
---

<figure {...slotName ? { slot: slotName } : {}}>
  <img
    src={imgSrc}
    class={imgClass}
    alt={alt}
    title={title}
    loading={loading}
    width={width}
    height={height}
    onerror="this.style.opacity='0.3';this.style.border='2px dashed #ccc'"
  />
  {caption && <figcaption class="caption">{caption}</figcaption>}
</figure>

<style>
  figure {
    margin: 0;
    padding: 0;
  }
  figure img {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
