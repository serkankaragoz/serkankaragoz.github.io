---
import PostMeta from '@components/blog/PostMeta.astro';
import ReadingProgress from '@components/ReadingProgress.astro';
import TOC from '@components/TOC.astro';
import { site } from '@config/site';
import { readingTime as calcReadingTime } from '@utils/reading-time';
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';

import Base from './Base.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  headings?: MarkdownHeading[];
}

const { post, headings = [] } = Astro.props;
const { title, description, date, tags = [], categories = [], robots, draft = false } = post.data;
const effectiveRobots = draft ? 'noindex, nofollow' : robots;

// Access distill-specific fields via type cast (added to schema in content.config.ts)
const postData = post.data as typeof post.data & {
  distillAuthors?: Array<{
    name: string;
    url?: string;
    affiliations?: { name: string };
  }>;
  bibliography?: string;
};

const authors = postData.distillAuthors ?? [];
const rt = post.body ? calcReadingTime(post.body) : 1;
---

<Base title={title} description={description} robots={effectiveRobots}>
  {site.features.progressBar && <ReadingProgress />}

  <div class="distill-page-container py-8">
    <div class="mx-auto flex max-w-5xl gap-8 px-4">
      <!-- TOC sidebar (desktop only) -->
      {
        headings.length > 0 && (
          <aside class="hidden w-52 flex-shrink-0 lg:block">
            <TOC headings={headings} />
          </aside>
        )
      }

      <!-- Main distill article -->
      <article class="distill-article min-w-0 flex-1">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="breadcrumb-nav">
          <a href={`${site.base}/blog/`} class="breadcrumb-link">← Blog</a>
        </nav>

        <!-- Distill-style header -->
        <header
          class="distill-header mb-8 border-b pb-6"
          style="border-color: var(--global-divider-color);"
        >
          <h1 class="distill-title">
            {title}
          </h1>

          {description && <p class="distill-description">{description}</p>}

          <!-- Authors block -->
          {
            authors.length > 0 && (
              <div class="distill-authors">
                {authors.map((author) => (
                  <div class="distill-author-block">
                    <span class="distill-author-name">
                      {author.url ? (
                        <a href={author.url} target="_blank" rel="noopener noreferrer">
                          {author.name}
                        </a>
                      ) : (
                        author.name
                      )}
                    </span>
                    {author.affiliations?.name && (
                      <span class="distill-affiliation">{author.affiliations.name}</span>
                    )}
                  </div>
                ))}
              </div>
            )
          }

          <PostMeta date={date} tags={tags} categories={categories} readingTime={rt} />
        </header>

        <!-- Article body — Distill-styled prose -->
        <div class="distill-content prose max-w-none" id="distill-post-content">
          <slot />
        </div>
      </article>
    </div>
  </div>

  <!-- Load distillpub scripts at end of body so custom elements upgrade -->
  <script is:inline src={`${import.meta.env.BASE_URL}assets/js/distillpub/template.v2.js`}></script>
  <script is:inline src={`${import.meta.env.BASE_URL}assets/js/distillpub/transforms.v2.js`}
  ></script>
  <script is:inline src={`${import.meta.env.BASE_URL}assets/js/distillpub/overrides.js`}></script>
</Base>

<!-- Code copy button -->
<script>
  function addCopyButtons() {
    const blocks = document.querySelectorAll('#distill-post-content pre');
    blocks.forEach((pre) => {
      if (pre.querySelector('.copy-btn')) return;
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.textContent = 'copy';
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (!code) return;
        await navigator.clipboard.writeText(code.innerText);
        btn.textContent = 'copied!';
        setTimeout(() => {
          btn.textContent = 'copy';
        }, 2000);
      });
      (pre as HTMLElement).style.position = 'relative';
      pre.appendChild(btn);
    });
  }
  document.addEventListener('astro:page-load', addCopyButtons);
</script>

<style>
  /* ── Distill-inspired article styles ── */

  .distill-title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: var(--global-text-color);
    font-family: var(--font-sans);
  }

  .distill-description {
    font-size: 1.15rem;
    color: var(--global-text-color-light);
    margin-bottom: 1.25rem;
    line-height: 1.6;
    font-style: italic;
  }

  .distill-authors {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .distill-author-block {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .distill-author-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--global-text-color);
  }

  .distill-author-name a {
    color: var(--global-theme-color);
    text-decoration: none;
  }

  .distill-author-name a:hover {
    text-decoration: underline;
  }

  .distill-affiliation {
    font-size: 0.8rem;
    color: var(--global-text-color-light);
  }

  /* Distill content — enhanced prose for academic style */
  .distill-content {
    font-size: 1rem;
    line-height: 1.8;
    color: var(--global-text-color);
  }

  /* Section headers with Distill-style left border accent */
  .distill-content :global(h2) {
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--global-divider-color);
    color: var(--global-text-color);
  }

  .distill-content :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--global-text-color);
  }

  /* Block quotes styled as Distill aside panels */
  .distill-content :global(blockquote) {
    border-left: 3px solid var(--global-theme-color);
    background-color: var(--global-card-bg-color);
    padding: 1rem 1.25rem;
    border-radius: 0 6px 6px 0;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--global-text-color-light);
  }

  /* Code copy button */
  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s;
    font-size: 0.7rem;
    font-family: var(--font-mono, monospace);
    background-color: var(--global-card-bg-color, #f5f5f5);
    color: var(--global-text-color-light, #888);
    line-height: 1.5;
  }

  pre:hover .copy-btn {
    opacity: 1;
  }

  .copy-btn:hover {
    background-color: var(--global-theme-color);
    color: var(--global-hover-text-color, #fff);
  }

  /* Distill note/callout helper class — use in MDX as <div class="distill-note"> */
  .distill-content :global(.distill-note) {
    background-color: var(--global-card-bg-color);
    border: 1px solid var(--global-divider-color);
    border-left: 4px solid var(--global-theme-color);
    padding: 1rem 1.25rem;
    border-radius: 0 6px 6px 0;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }

  /* Breadcrumb — mirrors Post.astro styling via global CSS, scoped here for the distill layout */
  .breadcrumb-nav {
    margin-bottom: 1rem;
  }

  .breadcrumb-link {
    font-size: 0.875rem;
    color: var(--global-text-color-light);
    text-decoration: none;
  }

  .breadcrumb-link:hover {
    color: var(--global-theme-color);
  }

  /* distillpub template.v2.js injects its own <style id="distill-prerendered-styles"> into
     <head> which includes Prism.js rules (color:black on code[class*="language-"]) and
     d-article aside (color:rgba(0,0,0,0.6)). Override any leaked hardcoded colours inside
     our distill content area so text is always readable in dark mode. */
  :global(html[data-theme='dark']) .distill-article {
    color: var(--global-text-color);
  }

  :global(html[data-theme='dark']) .distill-content :global(code),
  :global(html[data-theme='dark']) .distill-content :global(pre) {
    color: inherit;
  }
</style>
