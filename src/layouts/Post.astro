---
import PostMeta from '@components/blog/PostMeta.astro';
import RelatedPosts from '@components/blog/RelatedPosts.astro';
import SocialShare from '@components/blog/SocialShare.astro';
import Giscus from '@components/Giscus.astro';
import Newsletter from '@components/Newsletter.astro';
import ReadingProgress from '@components/ReadingProgress.astro';
import TOC from '@components/TOC.astro';
import { site } from '@config/site';
import { relatedPosts } from '@utils/posts';
import { readingTime as calcReadingTime } from '@utils/reading-time';
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';

import Base from './Base.astro';

interface Props {
  post: CollectionEntry<'posts'>;
  headings?: MarkdownHeading[];
}

const { post, headings = [] } = Astro.props;
const {
  title, description, date, lastmod, tags = [], categories = [],
  robots, draft = false,
  mermaid = false, chart_js = false, echarts = false, vega = false, plotly = false,
  pseudocode = false, typograms = false, tikzjax = false, map = false,
  img_comparison = false, code_diff = false, gallery = false, disqus = false,
} = post.data;

const effectiveRobots = draft ? 'noindex, nofollow' : robots;

const lastmodFormatted = lastmod
  ? lastmod.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const rt = post.body ? calcReadingTime(post.body, site.blog.wordsPerMinute) : 1;

// Related posts (if post has tags)
const allPosts = await getCollection('posts');
const related = post.data.relatedPosts ? relatedPosts(post, allPosts) : [];

// JSON-LD BlogPosting schema
const canonicalURL = new URL(`${site.base}/blog/${post.id}/`, site.url).toString();

// Generated OG image (falls back to static og.image if post has its own cover)
const ogImagePath = post.data.image
  ? new URL(post.data.image, site.url).toString()
  : new URL(`${site.base}/og/blog/${post.id}.png`, site.url).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  ...(description ? { description } : {}),
  datePublished: date.toISOString(),
  ...(lastmod ? { dateModified: lastmod.toISOString() } : {}),
  url: canonicalURL,
  author: {
    '@type': 'Person',
    name: site.author.name,
    url: site.url,
  },
  image: ogImagePath,
};
---

<Base title={title} description={description} robots={effectiveRobots} image={ogImagePath}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          {
            '@type': 'ListItem',
            position: 1,
            name: 'Blog',
            item: new URL(`${site.base}/blog/`, site.url).toString(),
          },
          { '@type': 'ListItem', position: 2, name: title, item: canonicalURL },
        ],
      })}
    />

    {vega && (
      <>
        {/* Preconnect to CDN to start TCP/TLS handshake early — reduces first-load
            latency for the three vega scripts (~1.6 MB total). */}
        <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
        {/* is:inline prevents Astro from bundling external URLs as `import"url"`.
            defer in <head> gives spec-guaranteed execution order: vega → vega-lite →
            vega-embed. vega-embed reads window.vega and window.vegaLite synchronously
            at execution time, so strict ordering is required. Scripts placed after
            </html> are in the browser's error-recovery zone where defer order is NOT
            guaranteed — that's why these must live in <head>. */}
        <script is:inline
          src="https://cdn.jsdelivr.net/npm/vega@5"
          integrity="sha384-NMXhl2TbCXxcN7o4ROC56Funm78m4AylL8gMg/7Kn4YU+wrm23K9l7cY8lDRXQ9d"
          crossorigin="anonymous"
          defer></script>
        <script is:inline
          src="https://cdn.jsdelivr.net/npm/vega-lite@5"
          integrity="sha384-D9LYH0esGjcxQJsBuxOuXtCDJGXRWW1+KhluzWPqi0rLJmiR/ygPChefaD+rFFDQ"
          crossorigin="anonymous"
          defer></script>
        <script is:inline
          src="https://cdn.jsdelivr.net/npm/vega-embed@6"
          integrity="sha384-M+Ax7e/WFJpxSOF09HzI+Sj4wg9ottVd/uxmV2ItGGh02fLH28t2FAOJx3TJBap5"
          crossorigin="anonymous"
          defer></script>
      </>
    )}

    {tikzjax && (
      <>
        {/* Preconnect to tikzjax.com to start TCP/TLS handshake before the large
            tikzjax.js bundle (~several hundred KB) and WASM (~2 MB) download. */}
        <link rel="preconnect" href="https://tikzjax.com" crossorigin />
        {/* tikzjax.js is a synchronous IIFE (webpack bundle) with no DOMContentLoaded
            or readyState logic — it scans for <script type="text/tikz"> elements
            immediately when it executes. It MUST run with defer so that the full document
            (including the body tikz elements) is already in the DOM at execution time.
            Without defer the script runs in <head> before the body is parsed and finds
            no tikz elements. The astro:after-swap handler below re-injects it for
            View Transitions navigations where the head script does not re-execute. */}
        <link rel="stylesheet" href="https://tikzjax.com/v1/fonts.css" />
        <script is:inline src="https://tikzjax.com/v1/tikzjax.js" defer></script>
      </>
    )}
  </Fragment>
  {site.features.progressBar && <ReadingProgress />}

  <div class="page-container py-8">
    <div class="flex gap-8">
      <!-- TOC sidebar (desktop only) -->
      {
        headings.length > 0 && (
          <aside class="hidden lg:block w-52 flex-shrink-0">
            <TOC headings={headings} />
          </aside>
        )
      }

      <!-- Post content -->
      <article class="flex-1 min-w-0">
        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb" class="breadcrumb-nav">
          <a href={`${site.base}/blog/`} class="breadcrumb-link">← Blog</a>
        </nav>

        <!-- Header -->
        <header class="post-header">
          <h1 class="post-title" style="margin-bottom: 0.75rem;">
            {title}
          </h1>

          <PostMeta date={date} tags={tags} categories={categories} readingTime={rt} />
          {lastmodFormatted && (
            <p class="post-lastmod" style="font-size: 0.8rem; color: var(--global-text-color-light); margin-top: 0.25rem;">
              Updated <time datetime={lastmod!.toISOString()}>{lastmodFormatted}</time>
            </p>
          )}
        </header>

        <!-- Body -->
        <div class="prose max-w-none" id="post-content">
          <slot />
        </div>

        <!-- Newsletter CTA (shown after post body when feature is enabled) -->
        {site.features.newsletter && <Newsletter />}

        <!-- Social sharing links -->
        {
          site.features.socialShare && (
            <SocialShare title={title} url={canonicalURL} description={description} />
          )
        }

        <!-- Related posts -->
        {related.length > 0 && <RelatedPosts posts={related} />}

        <!-- Comments -->
        {site.giscus.enabled && <Giscus />}
      </article>
    </div>
  </div>
</Base>

<!-- Code copy button (text-label approach, no innerHTML) -->
<script>
  function addCopyButtons() {
    const blocks = document.querySelectorAll('#post-content pre');
    blocks.forEach((pre) => {
      if (pre.querySelector('.copy-btn')) return;
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.textContent = 'copy';
      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (!code) return;
        await navigator.clipboard.writeText(code.innerText);
        btn.textContent = 'copied!';
        setTimeout(() => {
          btn.textContent = 'copy';
        }, 2000);
      });
      (pre as HTMLElement).style.position = 'relative';
      pre.appendChild(btn);
    });
  }
  document.addEventListener('astro:page-load', addCopyButtons);
</script>

<!-- Medium zoom for post images -->
<script>
  import mediumZoom from 'medium-zoom';
  let zoom: ReturnType<typeof mediumZoom> | null = null;

  function initZoom() {
    zoom?.detach();
    zoom = null;

    // All images in post content are zoomable by default.
    // Add class="no-zoom" (or use <Figure zoomable={false} />) to opt out.
    const imgs = document.querySelectorAll<HTMLImageElement>('#post-content img:not(.no-zoom)');
    if (imgs.length === 0) return;

    zoom = mediumZoom(imgs, { background: 'rgba(0,0,0,0.7)', margin: 24 });

    // Failsafe: medium-zoom's close() exits early when isAnimating === true.
    // isAnimating resets only when transitionend fires on the zoomed clone.
    // If the CSS transition doesn't start (transform set synchronously in the
    // same frame the clone is inserted), transitionend never fires and the zoom
    // gets permanently stuck open. Fix: after the open event, if the library's
    // own medium-zoom:opened event (fired inside _handleOpenEnd after the real
    // transitionend) hasn't fired within 400 ms, dispatch a synthetic
    // transitionend on the clone to unblock close().
    zoom.on('open', (event: Event) => {
      const original = event.target as HTMLElement;
      let resolved = false;

      const markResolved = () => { resolved = true; };
      original.addEventListener('medium-zoom:opened', markResolved, { once: true });

      setTimeout(() => {
        original.removeEventListener('medium-zoom:opened', markResolved);
        if (resolved) return;
        const clone = document.querySelector<HTMLElement>('.medium-zoom-image--opened');
        clone?.dispatchEvent(
          new TransitionEvent('transitionend', {
            bubbles: false,
            propertyName: 'transform',
            elapsedTime: 0.3,
          }),
        );
      }, 400);
    });
  }

  // Call immediately: the module is implicitly deferred so the DOM is ready, and this
  // handles the case where astro:page-load (fired from window.load in ClientRouter) fires
  // before this module script has been evaluated on an uncached first visit.
  initZoom();
  // Re-run on View Transitions (astro:page-load fires after each swap).
  document.addEventListener('astro:page-load', initZoom);
</script>

<!-- ── Per-post CDN widgets ──────────────────────────────────────────────── -->

{mermaid && (
  <>
    {/* is:inline + dynamic import — see PhotoSwipe for why <script type="module">{...} doesn't work.
        Astro renders mermaid code fences as <pre data-language="mermaid">, NOT pre.language-mermaid.
        On each page-load (hard or View Transitions), destroy any previous instance and re-render. */}
    <script is:inline>
      document.addEventListener('astro:page-load', function () {
        import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')
          .then(function (mod) {
            var mermaid = mod.default;
            var isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            mermaid.initialize({ startOnLoad: false, theme: isDark ? 'dark' : 'default' });

            // Astro/Shiki renders ```mermaid fences as <pre data-language="mermaid">
            document.querySelectorAll('pre[data-language="mermaid"]').forEach(function (pre) {
              var code = pre.querySelector('code');
              if (!code) return;
              var div = document.createElement('div');
              div.className = 'mermaid';
              div.textContent = code.textContent || '';
              pre.replaceWith(div);
            });

            mermaid.run();
          });
      });
    </script>
  </>
)}

{chart_js && (
  <script
    src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"
    integrity="sha384-jb8JQMbMoBUzgWatfe6COACi2ljcDdZQ2OxczGA3bGNeWe+6DChMTBJemed7ZnvJ"
    crossorigin="anonymous"
    defer></script>
)}

{echarts && (
  <script
    src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"
    integrity="sha384-pPi0zxBAoDu6+JXW/C68UZLvBUUtU+7zonhif43rqj7pxsGyqyqzcian2Rj37Rss"
    crossorigin="anonymous"
    defer></script>
)}

{/* vega CDN scripts moved to <Fragment slot="head"> above */}

{plotly && (
  <script
    src="https://cdn.jsdelivr.net/npm/plotly.js@2/dist/plotly.min.js"
    integrity="sha384-MqL7Cy3itNqCI1Wlc926K0XhyRKJ/NMqTaytIIEB+QIdInOploxqRIHRKLlhPykM"
    crossorigin="anonymous"
    defer></script>
)}

{pseudocode && (
  <>
    {/* CSS from CDN */}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/pseudocode@2.4.1/build/pseudocode.min.css"
      integrity="sha384-ff9LEHNvuDqxJT/JRjAeQ1cWTWambRLe5j49SnOzhaotb23KEQkCanV+ooL+ch4k"
      crossorigin="anonymous"
    />
    {/* Use the CDN build (pseudocode.min.js), loaded synchronously so window.pseudocode is
        set before our deferred module script calls renderElement. The Renderer is created
        lazily inside renderElement(), so katex does NOT need to be available at script
        load time — only at renderElement() call time.

        The npm browserify bundle has an unfixable issue in Vite's ESM output: the internal
        `katex = require('katex')` assignment to an undeclared free variable throws
        ReferenceError in strict mode. Even setting window.katex doesn't reliably fix it
        because Vite's module scope isolation can prevent free-variable global lookup. The
        CDN build bypasses this entirely: it runs in a normal browser context and reads
        window.katex as a global at Renderer construction time. */}
    <script is:inline
      src="https://cdn.jsdelivr.net/npm/pseudocode@2.4.1/build/pseudocode.min.js"
      integrity="sha384-i3+YbLfC66kxqBVtgH6I+lEFAr+57mVZY/MSthCK/oTPo0rWCRzW/kSg2mJnTKLs"
      crossorigin="anonymous"
    ></script>
    {/* Module script: import katex (bundled by Vite) and expose as window.katex so the
        CDN pseudocode.min.js Renderer can detect it via `typeof katex`. Then render all
        pre.pseudocode elements. Re-runs on every astro:page-load for View Transitions.
        data-psc-done prevents double-rendering on the initial hard load. */}
    <script>
      import katex from 'katex';

      (window as Window & { katex: typeof katex }).katex = katex;

      function runPseudocode() {
        const lib = (window as Window & { pseudocode?: { renderElement(el: HTMLElement): void } }).pseudocode;
        if (!lib) return;
        document.querySelectorAll<HTMLElement>('pre.pseudocode:not([data-psc-done])').forEach((el) => {
          el.setAttribute('data-psc-done', '1');
          try { lib.renderElement(el); } catch { el.style.display = ''; }
        });
      }
      runPseudocode();
      document.addEventListener('astro:page-load', runPseudocode);
    </script>
  </>
)}

{typograms && (
  <script is:inline src={`${import.meta.env.BASE_URL}assets/js/typograms.js`} type="module"></script>
)}

{tikzjax && (
  <>
    {/* tikzjax fonts + main script are in <Fragment slot="head"> for guaranteed defer ordering
        on initial hard load. This listener handles View Transitions: astro:after-swap fires only
        during VT, after the new body is in the DOM. Re-injecting tikzjax.js causes it to re-scan
        for <script type="text/tikz"> elements. Do NOT use astro:page-load here — it can fire
        while the WASM pipeline is still running, setting parentNode=null → silent failure. */}
    <script is:inline>
      document.addEventListener('astro:after-swap', function () {
        if (!document.querySelector('script[type="text/tikz"]')) return;
        var s = document.createElement('script');
        s.src = 'https://tikzjax.com/v1/tikzjax.js';
        document.head.appendChild(s);
      });
    </script>
  </>
)}

{map && (
  <>
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha384-sHL9NAb7lN7rfvG5lfHpm643Xkcjzp4jFvuavGOndn6pjVqS6ny56CAt3nsEVT4H"
      crossorigin="anonymous"
    />
    <script
      src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
      integrity="sha384-cxOPjt7s7Iz04uaHJceBmS+qpjv2JkIHNVcuOrM+YHwZOmJGBXI00mdUXEq65HTH"
      crossorigin="anonymous"
      defer></script>
  </>
)}

{img_comparison && (
  <>
    <script
      type="module"
      src="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/index.js"
      integrity="sha384-FCXElAg99YO+h+5Ky3gZ9cVwc8wyg6sq3jn79ugH0u5jh0NR5cvr0hGP+tzpjI+A"
      crossorigin="anonymous"></script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/img-comparison-slider@8/dist/styles.css"
      integrity="sha384-TYCxyqTqCrHZ0yHG2B7VENYnxnIBGWt8GHLLkGegAYCw+1UkvUd0YpsVPrt+8//z"
      crossorigin="anonymous"
    />
  </>
)}

{code_diff && (
  <>
    {/* pinned to diff2html@3.4.56 — update SRI when upgrading */}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/diff2html@3.4.56/bundles/css/diff2html.min.css"
      integrity="sha384-PdRCG/+r1waybtXfuDB9Kmv2h7AGoN6WaTZ5OF+ctPeR9BGne0FaKRQnUeGV4nDL"
      crossorigin="anonymous"
    />
    <script
      src="https://cdn.jsdelivr.net/npm/diff2html@3.4.56/bundles/js/diff2html-ui.min.js"
      integrity="sha384-NRd5i/CwvZ20mJEQt3yaDU1LeU+tu0bqyVYojXi8d7Lf1B0/TIs2K3FTvlf8aO7p"
      crossorigin="anonymous"
      defer></script>
  </>
)}

{gallery && (
  <>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.css"
      integrity="sha384-IfxC36XL/toUyJ939C73PcgMuRzAZuIzZxE38drsmO5p6jD7ei+Zx/1oA/0l8ysE"
      crossorigin="anonymous"
    />
    {/* is:inline + dynamic import() — Astro does not process <script type="module">{...}</script>
        JSX template literals as real ES modules, so static ESM import won't execute.
        Dynamic import() inside is:inline works correctly and survives View Transitions. */}
    <script is:inline>
      document.addEventListener('astro:page-load', function () {
        if (window.__pswpLightbox) {
          window.__pswpLightbox.destroy();
          window.__pswpLightbox = null;
        }
        if (!document.querySelector('#post-content a[data-pswp-width]')) return;
        import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe-lightbox.esm.js')
          .then(function (mod) {
            var PhotoSwipeLightbox = mod.default;
            window.__pswpLightbox = new PhotoSwipeLightbox({
              gallery: '#post-content',
              children: 'a[data-pswp-width]',
              pswpModule: function () {
                return import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.esm.js');
              },
            });
            window.__pswpLightbox.init();
          });
      });
    </script>
  </>
)}

{disqus && (
  <>
    <div id="disqus_thread" class="mt-8 pt-6" style="border-top: 1px solid var(--global-divider-color);"></div>
    <script is:inline define:vars={{ disqusUrl: Astro.url.href, disqusId: post.id, disqusShortname: site.comments.disqusShortname }}>
      var disqus_config = function () {
        this.page.url = disqusUrl;
        this.page.identifier = disqusId;
      };
      (function() {
        var d = document, s = d.createElement('script');
        s.src = `https://${disqusShortname}.disqus.com/embed.js`;
        s.setAttribute('data-timestamp', +new Date());
        (d.head || d.body).appendChild(s);
      })();
    </script>
  </>
)}

<style is:global>
  /* TikZJax processes <script type="text/tikz"> elements asynchronously (WASM).
     Show a subtle "Loading diagram…" placeholder while the WASM pipeline runs.
     Once tikzjax replaces the element with an <svg>, this rule no longer applies. */
  #post-content script[type="text/tikz"] {
    display: block;
    min-height: 3rem;
    background: repeating-linear-gradient(
      90deg,
      var(--global-card-bg-color, #f5f5f5) 0,
      var(--global-card-bg-color, #f5f5f5) 40%,
      color-mix(in srgb, var(--global-card-bg-color, #f5f5f5) 60%, transparent) 50%,
      var(--global-card-bg-color, #f5f5f5) 60%,
      var(--global-card-bg-color, #f5f5f5) 100%
    );
    background-size: 200% 100%;
    animation: tikz-shimmer 1.6s infinite;
    border-radius: 4px;
  }
  @keyframes tikz-shimmer {
    0%   { background-position: 100% 0; }
    100% { background-position: -100% 0; }
  }

  /* vega-embed injects .vega-embed { display: inline-block } into the page, which
     changes the chart container from block (full width) to inline-block (content-sized).
     Before the chart content renders, the container has 0 width, so charts using
     "width": "container" measure 0 and render invisible. Override to block so the
     container keeps its natural 100% width when vegaEmbed() measures it. */
  #post-content .vega-embed {
    display: block;
    width: 100%;
  }

  /* Copy button is dynamically injected via JS — scoped CSS won't reach it.
     Use :global so the class name isn't mangled with a data-astro-cid attribute. */
  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s;
    font-size: 0.7rem;
    font-family: var(--font-mono, monospace);
    background-color: var(--global-card-bg-color, #f5f5f5);
    color: var(--global-text-color-light, #888);
    line-height: 1.5;
  }
  pre:hover .copy-btn {
    opacity: 1;
  }
  .copy-btn:hover {
    background-color: var(--global-theme-color);
    color: var(--global-hover-text-color, #fff);
  }
</style>
