---
import PhotoCard from '@components/gallery/PhotoCard.astro';
import Pagination from '@components/Pagination.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const allPhotos = (await getCollection('photos')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const allCategories = [...new Set(allPhotos.flatMap((p) => p.data.categories))].sort();
const displayCategories =
  site.gallery.displayCategories.length > 0 ? site.gallery.displayCategories : allCategories;

const perPage = site.gallery.photosPerPage;
const totalPages = Math.ceil(allPhotos.length / perPage);
const pagePhotos = allPhotos.slice(0, perPage);
const base = site.base;
---

<Page title={site.gallery.name} description={site.gallery.description}>
  <div class="post">
    <div class="header-bar">
      <h1>{site.gallery.name}</h1>
      <h2>{site.gallery.description}</h2>
    </div>

    {
      displayCategories.length > 0 && (
        <div class="tag-category-list">
          <ul class="m-0 p-0">
            {displayCategories.map((cat, i) => (
              <>
                <li>
                  <Icon name="fa-solid:tag" />{' '}
                  <a href={`${base}/gallery/category/${cat}/`}>{cat}</a>
                </li>
                {i < displayCategories.length - 1 && <p>&bull;</p>}
              </>
            ))}
          </ul>
        </div>
      )
    }

    {
      pagePhotos.length === 0 ? (
        <p style="color: var(--global-text-color-light); padding-top: 2rem;">
          {site.gallery.emptyMessage}
        </p>
      ) : (
        <div class="photo-grid">
          {pagePhotos.map((photo) => (
            <PhotoCard photo={photo} />
          ))}
        </div>
      )
    }

    <Pagination
      currentPage={1}
      totalPages={totalPages}
      prevUrl={undefined}
      nextUrl={totalPages > 1 ? `${base}/gallery/page/2/` : undefined}
      basePath={`${base}/gallery/`}
    />
  </div>
</Page>

<style>
  .gallery-description {
    color: var(--global-text-color-light);
    font-size: 1rem;
    margin: 0 0 1.5rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    margin-top: 1.5rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 1024px) {
    .photo-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 576px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
