---
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', (p) => !p.data.hidden && !p.data.draft);
  const perPage = site.blog.postsPerPage;
  const years = [...new Set(allPosts.map((p) => p.data.date.getFullYear()))];

  return years.map((year) => {
    const yearPosts = allPosts
      .filter((p) => p.data.date.getFullYear() === year)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.max(1, Math.ceil(yearPosts.length / perPage));
    return {
      params: { year: String(year) },
      props: {
        year,
        posts: yearPosts.slice(0, perPage),
        currentPage: 1,
        totalPages,
      },
    };
  });
}

const { year, posts, currentPage, totalPages } = Astro.props;
const base = site.base;
---

<Page title={`Blog — ${year}`} description={`All posts from ${year}`}>
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{year}</h1>
      <p>
        <a href={`${base}/blog/`} style="color: var(--global-theme-color);">← Back to blog</a>
      </p>
    </header>
    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))
      }
    </ul>
    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      prevUrl={undefined}
      nextUrl={totalPages > 1 ? `${base}/blog/year/${year}/page/2/` : undefined}
      basePath={`${base}/blog/year/${year}/`}
    />
  </div>
</Page>
