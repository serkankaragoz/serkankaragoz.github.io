---
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { site } from '@config/site';
import PageLayout from '@layouts/Page.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const perPage = site.blog.postsPerPage;
  const postCategories = allPosts.flatMap((p) => p.data.categories);
  const allCategories = [...new Set([...postCategories, ...site.blog.displayCategories])];

  return allCategories.flatMap((category) => {
    const catPosts = allPosts
      .filter((p) => !p.data.hidden && !p.data.draft && p.data.categories.includes(category))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.ceil(catPosts.length / perPage);
    return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => {
      const page = i + 2;
      return {
        params: { category, page: String(page) },
        props: {
          posts: catPosts.slice((page - 1) * perPage, page * perPage),
          currentPage: page,
          totalPages,
        },
      };
    });
  });
}

const { category } = Astro.params;
const { posts, currentPage, totalPages } = Astro.props;
const base = site.base;
---

<PageLayout
  title={`Category: ${category} — Page ${currentPage}`}
  description={`Posts in category "${category}", page ${currentPage}`}
>
  <div class="mb-6">
    <a
      href={`${base}/blog/`}
      class="text-sm"
      style="color: var(--global-theme-color); text-decoration: none;"
    >
      &larr; All posts
    </a>
  </div>

  <h1
    class="mb-6 text-3xl font-bold"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    Category:
    <span
      class="badge-abbr ml-2"
      style="background-color: var(--global-text-color-light); color: var(--global-hover-text-color);"
    >
      {category}
    </span>
  </h1>

  <ul class="post-list">
    {
      posts.map((post) => (
        <li>
          <PostCard post={post} />
        </li>
      ))
    }
  </ul>

  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    prevUrl={currentPage === 2
      ? `${base}/blog/category/${category}/`
      : `${base}/blog/category/${category}/page/${currentPage - 1}/`}
    nextUrl={currentPage < totalPages
      ? `${base}/blog/category/${category}/page/${currentPage + 1}/`
      : undefined}
    basePath={`${base}/blog/category/${category}/`}
  />
</PageLayout>
