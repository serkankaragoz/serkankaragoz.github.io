---
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const perPage = site.blog.postsPerPage;
  const postCategories = allPosts.flatMap((p) => p.data.categories);
  const allCategories = [...new Set([...postCategories, ...site.blog.displayCategories])];

  return allCategories.map((category) => {
    const catPosts = allPosts
      .filter((p) => !p.data.hidden && !p.data.draft && p.data.categories.includes(category))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const totalPages = Math.max(1, Math.ceil(catPosts.length / perPage));
    return {
      params: { category },
      props: {
        posts: catPosts.slice(0, perPage),
        currentPage: 1,
        totalPages,
      },
    };
  });
}

const { category } = Astro.params;
const { posts, currentPage, totalPages } = Astro.props;
const base = site.base;
---

<Page title={`Category: ${category}`} description={`Posts in category "${category}"`}>
  <div class="mb-6">
    <a
      href={`${base}/blog/`}
      class="text-sm"
      style="color: var(--global-theme-color); text-decoration: none;"
    >
      &larr; All posts
    </a>
  </div>

  <h1
    class="mb-6 text-3xl font-bold"
    style="color: var(--global-text-color); font-family: var(--font-sans);"
  >
    Category:
    <span
      class="badge-abbr ml-2"
      style="background-color: var(--global-text-color-light); color: var(--global-hover-text-color);"
    >
      {category}
    </span>
  </h1>

  {
    posts.length === 0 ? (
      <p style="color: var(--global-text-color-light);">No posts found for this category.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <PostCard post={post} />
          </li>
        ))}
      </ul>
    )
  }

  <Pagination
    currentPage={currentPage}
    totalPages={totalPages}
    prevUrl={undefined}
    nextUrl={totalPages > 1 ? `${base}/blog/category/${category}/page/2/` : undefined}
    basePath={`${base}/blog/category/${category}/`}
  />
</Page>
