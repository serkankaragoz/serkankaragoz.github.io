---
import PostCard from '@components/blog/PostCard.astro';
import Pagination from '@components/Pagination.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { fetchExternalPosts } from '@utils/external-posts';
import { readingTime } from '@utils/reading-time';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const localPosts = (await getCollection('posts'))
  .filter((p) => !p.data.hidden && !p.data.draft)
  .sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.date.getTime() - a.data.date.getTime();
  });

const externalPosts = await fetchExternalPosts();

type LocalPost = (typeof localPosts)[number];
type ExternalPost = {
  external: true;
  id: string;
  url: string;
  data: {
    title: string;
    date: Date;
    description?: string;
    tags: string[];
    categories: string[];
    image?: string;
  };
  body?: undefined;
};

const allPosts: (LocalPost | ExternalPost)[] = [
  ...localPosts,
  ...externalPosts.map((ep) => ({
    external: true as const,
    id: ep.url,
    url: ep.url,
    body: undefined,
    data: {
      title: ep.title,
      date: ep.publishedDate,
      description: ep.description,
      tags: ep.tags,
      categories: ep.categories,
      image: undefined,
    },
  })),
].sort((a, b) => {
  const aPin = 'pinned' in a.data ? (a.data as { pinned?: boolean }).pinned : false;
  const bPin = 'pinned' in b.data ? (b.data as { pinned?: boolean }).pinned : false;
  if (aPin !== bPin) return aPin ? -1 : 1;
  return b.data.date.getTime() - a.data.date.getTime();
});

// Pinned (featured) local posts shown in card grid at top
const pinnedPosts = localPosts.filter((p) => p.data.pinned);

const perPage = site.blog.postsPerPage;
const totalPages = Math.ceil(allPosts.length / perPage);
const pagePosts = allPosts.slice(0, perPage);

const displayTags = site.blog.displayTags;
const displayCategories = site.blog.displayCategories;

// Grid column count for featured cards
const featuredCols = pinnedPosts.length >= 3 ? '3' : '2';

// Group pagePosts by year for the list section
const postsByYear = new Map<number, typeof pagePosts>();
for (const post of pagePosts) {
  const year = post.data.date.getFullYear();
  if (!postsByYear.has(year)) postsByYear.set(year, []);
  postsByYear.get(year)!.push(post);
}
const postYears = [...postsByYear.keys()].sort((a, b) => b - a);
---

<Page title="Blog" description={site.blog.description}>
  <!-- Header bar -->
  <div class="header-bar">
    <h1>{site.blog.name}</h1>
    <h2>{site.blog.description}</h2>
  </div>

  <!-- Tag / category list + all-tags link -->
  <div class="tag-category-list">
    <ul class="m-0 p-0">
      {
        displayTags.map((tag, i) => (
          <>
            <li>
              <Icon name="fa-solid:hashtag" /> <a href={`${site.base}/blog/tag/${tag}/`}>{tag}</a>
            </li>
            {i < displayTags.length - 1 && <p>&bull;</p>}
          </>
        ))
      }
      {displayTags.length > 0 && displayCategories.length > 0 && <p>&bull;</p>}
      {
        displayCategories.map((cat, i) => (
          <>
            <li>
              <Icon name="fa-solid:tag" /> <a href={`${site.base}/blog/category/${cat}/`}>{cat}</a>
            </li>
            {i < displayCategories.length - 1 && <p>&bull;</p>}
          </>
        ))
      }
      {(displayTags.length > 0 || displayCategories.length > 0) && <p>&bull;</p>}
      <li>
        <Icon name="fa-solid:tags" />{' '}
        <a href={`${site.base}/blog/tags/`}>all tags</a>
      </li>
    </ul>
  </div>

  <!-- Featured / Pinned posts card grid -->
  {
    pinnedPosts.length > 0 && (
      <>
        <br />
        <div class="featured-posts container">
          <div class={`row row-cols-${featuredCols}`}>
            {pinnedPosts.map((post) => {
              const mins = post.body ? readingTime(post.body, site.blog.wordsPerMinute) : 1;
              const year = post.data.date.getFullYear();
              return (
                <div class="col mb-4">
                  <a href={`${site.base}/blog/${post.id}/`}>
                    <div class="card hoverable">
                      <div class="row g-0">
                        <div class="col-md-12">
                          <div class="card-body">
                            <div class="float-right">
                              <Icon name="fa-solid:thumbtack" style="font-size:0.75rem;" />
                            </div>
                            <h3 class="card-title text-lowercase">{post.data.title}</h3>
                            {post.data.description && (
                              <p class="card-text">{post.data.description}</p>
                            )}
                            <p class="post-meta">
                              {mins} min read &nbsp;&middot;&nbsp;
                              <span>
                                <Icon name="fa-solid:calendar" style="font-size:0.75rem;" /> {year}
                              </span>
                            </p>
                          </div>
                        </div>
                      </div>
                    </div>
                  </a>
                </div>
              );
            })}
          </div>
        </div>
        <hr style="margin-bottom: 2rem;" />
      </>
    )
  }

  <!-- Post list grouped by year -->
  {
    pagePosts.length === 0 ? (
      <p style="color: var(--global-text-color-light); padding-top: 2rem;">
        {site.blog.emptyMessage}
      </p>
    ) : (
      postYears.map((year) => (
        <>
          <h2 class="year">
            <a
              href={`${site.base}/blog/year/${year}/`}
              style="color: inherit; text-decoration: none;"
            >
              {year}
            </a>
          </h2>
          <ul class="post-list">
            {postsByYear.get(year)!.map((post) => (
              <li>
                <PostCard post={post} />
              </li>
            ))}
          </ul>
        </>
      ))
    )
  }

  <Pagination
    currentPage={1}
    totalPages={totalPages}
    prevUrl={undefined}
    nextUrl={totalPages > 1 ? `${site.base}/blog/page/2/` : undefined}
    basePath={`${site.base}/blog/`}
  />
</Page>
