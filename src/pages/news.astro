---
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { getCollection, render } from 'astro:content';

const announcements = (await getCollection('announcements'))
  .filter((e) => !e.data.hidden)
  .sort((a, b) => {
    if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
    return b.data.date.getTime() - a.data.date.getTime();
  });

const rendered = await Promise.all(
  announcements.map(async (item) => ({ item, rendered: await render(item) })),
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Page title="News" description={`News and announcements from ${site.author.name}`}>
  <div class="post">
    <div class="header-bar">
      <h1>Son gelişmeler</h1>
    </div>
    <article>
      {
        rendered.length === 0 ? (
          <p style="color: var(--global-text-color-light);">No announcements yet.</p>
        ) : (
          <table style="width: 100%; border-collapse: collapse;">
            <tbody>
              {rendered.map(({ item, rendered: { Content } }) => (
                <tr style="border-bottom: 1px solid var(--global-divider-color);">
                  <td style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;">
                    {formatDate(item.data.date)}
                  </td>
                  <td style="padding: 0.5rem 0; font-size: 0.9rem; color: var(--global-text-color);">
                    <Content />
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )
      }
    </article>
  </div>
</Page>

<style>
  .post-header {
    margin-bottom: 1.5rem;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--global-text-color);
    font-family: var(--font-sans);
    margin-bottom: 0;
  }
</style>
