---
import Giscus from '@components/Giscus.astro';
import { site } from '@config/site';
import Page from '@layouts/Page.astro';
import { withBase } from '@utils/base';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const {
  title,
  description,
  img,
  img_alt,
  url,
  github,
  giscus_comments,
  redirect,
} = project.data;

// If this project has a redirect, forward immediately
if (redirect) {
  return Astro.redirect(redirect);
}

const githubUrl = github ? `https://github.com/${github}` : undefined;

// Generated OG image (falls back to hero image if present)
const ogImagePath = img
  ? new URL(img, site.url).toString()
  : new URL(`${site.base}/og/project/${project.id}.png`, site.url).toString();

---

<Page title={title} description={description} image={ogImagePath}>
  <div class="post">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="breadcrumb-nav">
      <a href={`${site.base}/projects/`} class="breadcrumb-link">← Projects</a>
    </nav>

    <!-- Page header -->
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-description">{description}</p>}

      <!-- External links -->
      {
        (githubUrl || url) && (
          <div class="project-links">
            {githubUrl && (
              <a
                href={githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="project-btn project-btn--primary"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 16 16"
                  fill="currentColor"
                  width="16"
                  height="16"
                  aria-hidden="true"
                >
                  <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
                </svg>
                GitHub
              </a>
            )}
            {url && url !== githubUrl && (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="project-btn project-btn--secondary"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  width="16"
                  height="16"
                  aria-hidden="true"
                >
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                  <polyline points="15 3 21 3 21 9" />
                  <line x1="10" y1="14" x2="21" y2="3" />
                </svg>
                Website
              </a>
            )}
          </div>
        )
      }
    </header>

    <article>
      <!-- Hero image -->
      {
        img && (
          <div class="project-hero">
            <img
              src={withBase(img)}
              alt={img_alt ?? title}
              loading="eager"
              class="img-fluid z-depth-1 rounded"
            />
          </div>
        )
      }

      <!-- Body content -->
      <div class="prose" id="project-content">
        <Content />
      </div>
    </article>

    <!-- Giscus comments -->
    {giscus_comments && <Giscus />}
  </div>
</Page>

<!-- Medium zoom for project images -->
<script>
  import mediumZoom from 'medium-zoom';
  let zoom: ReturnType<typeof mediumZoom> | null = null;

  function initZoom() {
    zoom?.detach();
    zoom = null;

    const imgs = document.querySelectorAll<HTMLImageElement>('#project-content img:not(.no-zoom)');
    if (imgs.length === 0) return;

    zoom = mediumZoom(imgs, { background: 'rgba(0,0,0,0.7)', margin: 24 });

    zoom.on('open', (event: Event) => {
      const original = event.target as HTMLElement;
      let resolved = false;

      const markResolved = () => {
        resolved = true;
      };
      original.addEventListener('medium-zoom:opened', markResolved, { once: true });

      setTimeout(() => {
        original.removeEventListener('medium-zoom:opened', markResolved);
        if (resolved) return;
        const clone = document.querySelector<HTMLElement>('.medium-zoom-image--opened');
        clone?.dispatchEvent(
          new TransitionEvent('transitionend', {
            bubbles: false,
            propertyName: 'transform',
            elapsedTime: 0.3,
          }),
        );
      }, 400);
    });
  }

  document.addEventListener('astro:page-load', initZoom);
</script>

<style>
  /* ── Post structure (matches al-folio page.liquid) ───────────────────────── */
  .post {
    padding-top: 0;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--global-text-color);
    font-family: var(--font-sans);
    margin-bottom: 0.5rem;
  }

  .post-description {
    font-size: 1.1rem;
    color: var(--global-text-color-light);
    margin-bottom: 1rem;
  }

  /* ── External link buttons ─────────────────────────────────────────────── */
  .project-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .project-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }

  .project-btn--primary {
    background-color: var(--global-theme-color);
    color: var(--global-hover-text-color);
  }

  .project-btn--primary:hover {
    opacity: 0.85;
  }

  .project-btn--secondary {
    background-color: transparent;
    color: var(--global-text-color);
    border: 1px solid var(--global-divider-color);
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .project-btn--secondary:hover {
    border-color: var(--global-theme-color);
    color: var(--global-theme-color);
  }

  /* ── Hero image ───────────────────────────────────────────────────────── */
  .project-hero {
    margin-bottom: 2rem;
  }

  .img-fluid {
    max-width: 100%;
    height: auto;
    display: block;
  }

  .rounded {
    border-radius: 4px;
  }

  .z-depth-1 {
    box-shadow:
      0 2px 5px 0 rgba(0, 0, 0, 0.16),
      0 2px 10px 0 rgba(0, 0, 0, 0.12);
  }

</style>
