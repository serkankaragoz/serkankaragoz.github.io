---
import ProfilePhoto from '@components/about/ProfilePhoto.astro';
import SocialLinks from '@components/SocialLinks.astro';
import { site } from '@config/site';
import Base from '@layouts/Base.astro';
import { getCollection, render } from 'astro:content';

import AboutContent from '../data/about.mdx';

// Announcements
const allAnnouncements = site.announcements.enabled
  ? (await getCollection('announcements'))
      .filter((e) => !e.data.hidden)
      .sort((a, b) => {
        if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
        return b.data.date.getTime() - a.data.date.getTime();
      })
      .slice(0, site.announcements.limit)
  : [];

// Latest posts
const allPosts = site.latestPosts.enabled
  ? (await getCollection('posts'))
      .filter((p) => !p.data.hidden)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .slice(0, site.latestPosts.limit)
  : [];

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });

// Pre-render announcement content
const renderedAnnouncements = await Promise.all(
  allAnnouncements.map(async (item) => ({ item, rendered: await render(item) })),
);
---

<Base isHome={true}>
  <div class="post page-container py-8">
    <header class="post-header">
      <h1
        class="post-title"
        style="font-family: var(--font-sans); color: var(--global-text-color);"
      >
        {(site.title as string) === 'blank' ? site.author.name : site.title}
      </h1>
      {
        site.author.subtitle && (
          <p
            class="desc"
            style="color: var(--global-text-color-light);"
            set:html={site.author.subtitle}
          />
        )
      }
    </header>

    <article>
      <!-- Profile photo (floats right by default) -->
      <ProfilePhoto align="right" />

      <div class="clearfix">
        <!-- Bio content from about.mdx -->
        <div class="prose max-w-none">
          <AboutContent />
        </div>
      </div>

      <!-- Social icons -->
      {
        site.socials && (
          <div class="social mt-6">
            <div class="contact-icons">
              <SocialLinks />
            </div>
          </div>
        )
      }

      <!-- Announcements / News -->
      {
        site.announcements.enabled && allAnnouncements.length > 0 && (
          <section class="mt-8">
            <h2 style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.3rem;">
              <a href={`${site.base}/news/`} style="color: inherit; text-decoration: none;">
                Son gelişmeler
              </a>
            </h2>
            <div class={site.announcements.scrollable ? 'scrollable-list' : ''}>
              <table style="width: 100%; border-collapse: collapse;">
                <tbody>
                  {renderedAnnouncements.map(({ item, rendered: { Content } }) => (
                    <tr style="border-bottom: 1px solid var(--global-divider-color);">
                      <td style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;">
                        {formatDate(item.data.date)}
                      </td>
                      <td style="padding: 0.5rem 0; font-size: 0.9rem; color: var(--global-text-color);">
                        <Content />
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )
      }

      <!-- Latest posts -->
      {
        site.latestPosts.enabled && allPosts.length > 0 && (
          <section class="mt-8">
            <h2 style="color: var(--global-text-color); border-bottom: 1px solid var(--global-divider-color); padding-bottom: 0.3rem;">
              <a href={`${site.base}/blog/`} style="color: inherit; text-decoration: none;">
                Son yazılar
              </a>
            </h2>
            <div class={site.latestPosts.scrollable ? 'scrollable-list' : ''}>
              <table style="width: 100%; border-collapse: collapse;">
                <tbody>
                  {allPosts.map((post) => (
                    <tr style="border-bottom: 1px solid var(--global-divider-color);">
                      <td style="padding: 0.5rem 1rem 0.5rem 0; white-space: nowrap; vertical-align: top; color: var(--global-text-color-light); font-size: 0.8rem;">
                        {formatDate(post.data.date)}
                      </td>
                      <td style="padding: 0.5rem 0; font-size: 0.9rem;">
                        <a
                          href={`${site.base}/blog/${post.id}/`}
                          style="color: var(--global-theme-color); text-decoration: none;"
                        >
                          {post.data.title}
                        </a>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )
      }
    </article>
  </div>
</Base>

<style>
  .clearfix::after {
    content: '';
    display: table;
    clear: both;
  }
  .post-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .desc {
    font-size: 1rem;
    margin-bottom: 1rem;
  }
</style>
