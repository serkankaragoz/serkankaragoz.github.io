{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Book frontmatter",
  "type": "object",
  "required": ["title", "author"],
  "properties": {
    "title": { "type": "string", "description": "Book title" },
    "author": { "type": "string", "description": "Author name(s)" },
    "cover": { "type": "string", "description": "Path to cover image in public/assets/img/book_covers/" },
    "olid": { "type": "string", "description": "Open Library ID for cover lookup (e.g. OL43499941M)" },
    "isbn": { "type": "string", "description": "ISBN for cover lookup (digits only, dashes optional)" },
    "status": {
      "type": "string",
      "enum": ["reading", "finished", "queued", "paused", "abandoned", "interested", "reread"],
      "description": "Reading status"
    },
    "stars": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Star rating 1–5"
    },
    "started": { "type": "string", "format": "date", "description": "Date started reading (YYYY-MM-DD)" },
    "finished": { "type": "string", "format": "date", "description": "Date finished reading (YYYY-MM-DD)" },
    "released": { "type": "number", "description": "Original publication year" },
    "buy_link": { "type": "string", "format": "uri", "description": "Link to buy the book" },
    "goodreads_review": { "type": "string", "description": "Goodreads review ID" },
    "categories": { "type": "string", "description": "Comma-separated categories/genres" },
    "importance": { "type": "number", "default": 999, "description": "Sort order within the same year" }
  },
  "additionalProperties": false
}
