{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Teaching / course frontmatter",
  "type": "object",
  "required": ["title"],
  "properties": {
    "title": { "type": "string", "description": "Course title" },
    "code": { "type": "string", "description": "Short course code (e.g. PHYS 401)" },
    "description": { "type": "string", "description": "Course description" },
    "term": { "type": "string", "description": "Term when the course is offered (e.g. Spring 2024)" },
    "institution": { "type": "string", "description": "Institution name" },
    "url": { "type": "string", "format": "uri", "description": "Course website or syllabus URL" },
    "importance": { "type": "number", "default": 999, "description": "Sort order — lower numbers appear first" },
    "category": {
      "type": "string",
      "enum": ["current", "past"],
      "default": "current",
      "description": "Whether the course is current or past"
    }
  },
  "additionalProperties": false
}
