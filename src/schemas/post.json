{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Post frontmatter",
  "type": "object",
  "required": ["title", "date"],
  "properties": {
    "title": { "type": "string", "description": "Post title" },
    "date": { "type": "string", "format": "date", "description": "Publication date (YYYY-MM-DD)" },
    "description": { "type": "string", "description": "Short description for SEO and listings" },
    "tags": { "type": "array", "items": { "type": "string" }, "description": "Post tags" },
    "categories": { "type": "array", "items": { "type": "string" }, "description": "Post categories" },
    "math": { "type": "boolean", "default": false, "description": "Enable KaTeX math rendering" },
    "toc": { "type": "boolean", "default": true, "description": "Show table of contents sidebar" },
    "relatedPosts": { "type": "boolean", "default": false, "description": "Show related posts section" },
    "pinned": { "type": "boolean", "default": false, "description": "Pin to top of blog listing" },
    "hidden": { "type": "boolean", "default": false, "description": "Hide from listing (accessible via URL)" },
    "draft": { "type": "boolean", "default": false, "description": "Exclude from listings and search index until published" },
    "robots": { "type": "string", "description": "Override robots meta tag (e.g. noindex, nofollow)" },
    "lastmod": { "type": "string", "format": "date", "description": "Last modified date — shown in header and JSON-LD dateModified" },
    "redirect": { "type": "string", "format": "uri", "description": "Redirect to this URL instead of rendering content" },
    "image": { "type": "string", "description": "Hero/thumbnail image path" },
    "distill": { "type": "boolean", "default": false, "description": "Render as a Distill article" },
    "distillAuthors": {
      "type": "array",
      "description": "Authors for Distill-style posts",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "affiliations": {
            "type": "object",
            "properties": { "name": { "type": "string" } }
          }
        },
        "required": ["name"]
      }
    },
    "bibliography": { "type": "string", "description": "BibTeX bibliography file reference for Distill posts" },
    "citation_key": { "type": "string", "description": "Citation key for this post" },
    "mermaid": { "type": "boolean", "default": false, "description": "Load Mermaid diagram rendering" },
    "chart_js": { "type": "boolean", "default": false, "description": "Load Chart.js" },
    "echarts": { "type": "boolean", "default": false, "description": "Load Apache ECharts" },
    "vega": { "type": "boolean", "default": false, "description": "Load Vega/Vega-Lite" },
    "plotly": { "type": "boolean", "default": false, "description": "Load Plotly.js" },
    "pseudocode": { "type": "boolean", "default": false, "description": "Load pseudocode.js" },
    "typograms": { "type": "boolean", "default": false, "description": "Load Typograms" },
    "tikzjax": { "type": "boolean", "default": false, "description": "Load TikzJax" },
    "map": { "type": "boolean", "default": false, "description": "Load Leaflet maps" },
    "img_comparison": { "type": "boolean", "default": false, "description": "Load img-comparison-slider" },
    "code_diff": { "type": "boolean", "default": false, "description": "Load Diff2Html" },
    "gallery": { "type": "boolean", "default": false, "description": "Load PhotoSwipe gallery" },
    "disqus": { "type": "boolean", "default": false, "description": "Enable Disqus comments" }
  },
  "additionalProperties": false
}
