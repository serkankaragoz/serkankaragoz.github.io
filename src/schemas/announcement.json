{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Announcement frontmatter",
  "type": "object",
  "required": ["date"],
  "properties": {
    "date": { "type": "string", "format": "date", "description": "Announcement date (YYYY-MM-DD)" },
    "pinned": { "type": "boolean", "default": false, "description": "Pin to top of announcements list" },
    "hidden": { "type": "boolean", "default": false, "description": "Hide from the announcements list" }
  },
  "additionalProperties": false
}
