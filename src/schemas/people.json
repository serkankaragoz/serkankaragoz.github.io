{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "People / lab member frontmatter",
  "type": "object",
  "required": ["name", "role"],
  "properties": {
    "name": { "type": "string", "description": "Full name" },
    "role": { "type": "string", "description": "Role or title (e.g. PhD Student, Postdoc)" },
    "photo": { "type": "string", "description": "Photo path in public/assets/img/" },
    "description": { "type": "string", "description": "Brief description or research interests" },
    "website": { "type": "string", "format": "uri", "description": "Personal website URL" },
    "github": { "type": "string", "description": "GitHub username" },
    "scholar": { "type": "string", "description": "Google Scholar user ID" },
    "orcid": { "type": "string", "description": "ORCID ID" },
    "importance": { "type": "number", "default": 999, "description": "Sort order — lower numbers appear first" },
    "group": {
      "type": "string",
      "enum": ["current", "alumni"],
      "default": "current",
      "description": "Group membership: current or alumni"
    }
  },
  "additionalProperties": false
}
